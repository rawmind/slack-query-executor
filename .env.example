# ─────────────────────────────────────────────
# Phase 1: Bot Foundation
# ─────────────────────────────────────────────

# Slack Bot Token (xoxb-...)
# Source: Slack App UI → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=

# Slack App-Level Token (xapp-...) — required for Socket Mode
# Source: Slack App UI → Basic Information → App-Level Tokens
#         Create a token with the connections:write scope
SLACK_APP_TOKEN=

# Slack Channel ID (C...) — the single channel the bot monitors
# Source: Right-click the channel in Slack → Copy link;
#         the C... part is the channel ID
SLACK_CHANNEL_ID=

# ─────────────────────────────────────────────
# Phase 2: Approval Gate (uncomment when needed)
# ─────────────────────────────────────────────

# Slack User Group ID for approvers (S...)
# Source: Slack App UI or API: usergroups.list
# APPROVER_USERGROUP_ID=

# Emoji name (without colons) that triggers query execution
# Example: white_check_mark
# APPROVE_EMOJI=white_check_mark

# ─────────────────────────────────────────────
# Phase 3: MongoDB Execution (uncomment when needed)
# ─────────────────────────────────────────────

# MongoDB connection URI
# MONGODB_URI=mongodb://localhost:27017

# MongoDB database name to run queries against
# MONGODB_DATABASE=

# Maximum number of documents returned per query (default: 100)
# RESULT_LIMIT=100
